# Cyprus Bookkeeping SaaS — environment template
# Copy to .env (web/.env.local for Next.js, api/.env for FastAPI) and fill in.
# Never commit .env files.

# ============================================================================
# Supabase project — used by web + api
# ============================================================================
SUPABASE_URL=https://noxvmnxrqlzsdfngfiww.supabase.co
SUPABASE_PROJECT_REF=noxvmnxrqlzsdfngfiww
SUPABASE_REGION=eu-west-1

# Publishable / anon key — safe for client code, read access only.
# Get from: https://supabase.com/dashboard/project/noxvmnxrqlzsdfngfiww/settings/api
SUPABASE_PUBLISHABLE_KEY=

# Service-role key — SERVER-ONLY. Never expose to a browser. Bypasses RLS.
# Used by the Next.js admin client (auth.admin.inviteUserByEmail, sessions
# table read) and the FastAPI principal resolver. Same dashboard page;
# section "Service role secret".
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (migrations only; never for runtime queries).
SUPABASE_DB_URL=

# ============================================================================
# Next.js web app — web/.env.local
# ============================================================================
# Next.js requires the NEXT_PUBLIC_ prefix for browser-exposed env vars.
# These mirror the SUPABASE_* values above.
NEXT_PUBLIC_SUPABASE_URL=https://noxvmnxrqlzsdfngfiww.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Public origin used to build outbound URLs (email confirmation links,
# password-reset links, invitation accept URLs, OAuth redirect URIs).
# REQUIRED in production — lib/app-origin.ts throws if unset and NODE_ENV
# is "production". In development the helper falls back to localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OAuth token-at-rest encryption key — 32 bytes hex (64 chars). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used by lib/integration-token-encryption.ts to AES-256-GCM encrypt
# Google access + refresh tokens before they hit business_integrations.
INTEGRATION_TOKEN_ENC_KEY=

# Google OAuth client (B02·P08 — Gmail + Drive integration).
# Create in Google Cloud Console; register redirect_uri:
# `${NEXT_PUBLIC_SITE_URL}/oauth/google/callback`. EU consent screen
# required per Stage 1 EU-storage decision.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ============================================================================
# FastAPI api — api/.env (loaded by pydantic-settings)
# ============================================================================
# JWT verification — Supabase signs session JWTs with HS256 over a shared
# secret. The FastAPI dependency verifies the bearer token using this key
# before resolving the PrincipalContext.
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWKS_URL=https://noxvmnxrqlzsdfngfiww.supabase.co/auth/v1/.well-known/jwks.json

# ============================================================================
# Misc
# ============================================================================
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=info
