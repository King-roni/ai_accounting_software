# ─────────────────────────────────────────────────────────────────────────────
# API (FastAPI) environment — read by pydantic-settings (case-insensitive).
#
#   1Password users : ./scripts/sync-env.sh   (runs `op inject` → api/.env)
#   Manual users    : copy to api/.env and replace the 1Password reference
#                     (the op-prefixed line) with the value.
#
# api/.env is gitignored. The API authenticates via JWKS — there is NO JWT secret.
# Actual env vars take precedence over this file, so `op run` also works.
# See docs/ENV_SETUP.md.
# ─────────────────────────────────────────────────────────────────────────────

# ── Public / non-secret config ────────────────────────────────────────────────
SUPABASE_URL=https://noxvmnxrqlzsdfngfiww.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_mZDc60kP5EHJSFeORa2HZA_BfB-Cinq
SUPABASE_PROJECT_REF=noxvmnxrqlzsdfngfiww
SUPABASE_JWT_AUDIENCE=authenticated
APP_ENV=local
LOG_LEVEL=info

# ── Secret (resolved from 1Password) ──────────────────────────────────────────
# Service-role key BYPASSES RLS — server only.
SUPABASE_SERVICE_ROLE_KEY=op://Boekhoudings-Dev/supabase/service_role_key
