# R4 integration secrets — scratch inbox for pushing into 1Password.
#
#   cp secrets.inbox.env.example secrets.inbox.env
#   # fill in the values you have (leave the rest out — partial is fine)
#   ./scripts/push-secrets.sh        # uploads them to the vault
#   rm secrets.inbox.env             # delete once pushed
#
# secrets.inbox.env is gitignored. NEVER commit real values. You don't need all
# of these — start with ANTHROPIC_API_KEY; add the rest as you create accounts.

# Tier-3 AI (Block 06) — console.anthropic.com
ANTHROPIC_API_KEY=

# Google Document AI OCR (Block 09) — GCP → Document AI
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
# Paste the service-account JSON on ONE line (or store it in 1Password directly).
GOOGLE_DOCUMENT_AI_SA_JSON=

# Google OAuth for Gmail/Drive finders — GCP → Credentials → OAuth client
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# RFC-3161 timestamping authority (audit-chain anchoring, Block 01)
TSA_URL=
TSA_USERNAME=
TSA_PASSWORD=

# Envelope-encryption backend (KEK/DEK) — only if you run HashiCorp Vault
VAULT_ADDR=
VAULT_TOKEN=
