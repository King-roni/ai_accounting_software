# ─────────────────────────────────────────────────────────────────────────────
# Web (Next.js) environment — Cyprus Bookkeeping SaaS
#
# This file is BOTH the committed example AND the `op inject` source template.
#   1Password users : ./scripts/sync-env.sh   (runs `op inject` → web/.env.local)
#   Manual users    : copy to web/.env.local and replace each 1Password reference
#                     (the op-prefixed lines) with the real value.
#
# web/.env.local is gitignored — NEVER commit real secret values.
# Public NEXT_PUBLIC_* values are safe to expose (RLS protects the data).
# See Docs/ENV_SETUP.md for the full runbook.
# ─────────────────────────────────────────────────────────────────────────────

# ── Public (inlined into the browser bundle) ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://noxvmnxrqlzsdfngfiww.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_mZDc60kP5EHJSFeORa2HZA_BfB-Cinq
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Server-only config (not NEXT_PUBLIC_, but not secret) ─────────────────────
API_BASE_URL=http://localhost:8000

# ── Secrets (resolved from 1Password) ─────────────────────────────────────────
# Service-role key BYPASSES RLS — server only, never sent to the browser.
SUPABASE_SERVICE_ROLE_KEY=op://Boekhoudings-Dev/supabase/service_role_key
# AES-256-GCM master key for OAuth (Gmail/Drive) token storage — 32 bytes hex (64 chars).
INTEGRATION_TOKEN_ENC_KEY=op://Boekhoudings-Dev/web/integration_token_enc_key
