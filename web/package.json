    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
